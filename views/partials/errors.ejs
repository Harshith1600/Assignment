<%
  var errorsArray = [];
  if (typeof err !== 'undefined' && err && err.length > 0) {
    errorsArray = err;
  } else if (typeof errors !== 'undefined' && errors && errors.length > 0) {
    errorsArray = errors;
  }
%>
<% if (errorsArray.length > 0) { %>
  <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
    <ul>
      <% errorsArray.forEach(function(error) { %>
        <li><%= error %></li>
      <% }) %>
    </ul>
  </div>
<% } %>