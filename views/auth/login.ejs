<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
  <%- include('../partials/nav') %>

  <main class="container mx-auto mt-16 px-4 flex justify-center">
    <%-include('../partials/errors')%>
    <div class="w-full max-w-md">
      <div class="bg-white rounded-xl shadow-xl overflow-hidden">
        <div class="bg-gradient-to-r from-red-500 to-red-600 p-8 text-center">
          <h1 class="text-4xl font-bold text-white">👋 Welcome Back</h1>
          <p class="text-red-100 mt-2">Sign in to your account</p>
        </div>
        
        <form action="/login" method="POST" class="p-8">
          <div class="mb-6">
            <label class="block text-gray-700 font-semibold mb-2">Email</label>
            <input type="email" name="email"
              placeholder="Enter your email"
              required
              value="<%=oldInput!=='undefined'?oldInput.email:''%>"
              class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" />
          </div>

          <div class="mb-6">
            <label class="block text-gray-700 font-semibold mb-2">Password</label>
            <input type="password" name="password"
              placeholder="Enter your password"
              required
              class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" />
          </div>
            
          <input type="submit" value="Login Now"
            class="w-full bg-gradient-to-r from-red-500 to-red-600 text-white py-3 rounded-lg hover:shadow-lg hover:from-red-600 hover:to-red-700 cursor-pointer font-semibold transition duration-300" />
          
          <p class="text-center text-gray-600 mt-6">Don't have an account? <a href="/signup" class="text-red-500 font-semibold hover:text-red-700">Sign up here</a></p>
        </form>
      </div>
    </div>
  </main>
</body>
</html>