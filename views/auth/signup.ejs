<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
  <%- include('../partials/nav') %>
  <main class="container mx-auto mt-12 px-4 flex justify-center pb-12">
    <div class="w-full max-w-lg">
      <div class="bg-white rounded-xl shadow-xl overflow-hidden">
        <div class="bg-gradient-to-r from-red-500 to-red-600 p-8 text-center">
          <h1 class="text-4xl font-bold text-white">🎉 Join Us Today</h1>
          <p class="text-red-100 mt-2">Create your account and start exploring</p>
        </div>
        
        <form action="/signup" method="POST" class="p-8">
           <%-include('../partials/errors')%>
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div>
              <label class="block text-gray-700 font-semibold mb-2">First Name</label>
              <input type="text" name="firstName"
                placeholder="First Name"
                value="<%=oldInput!=='undefined'?oldInput.firstName:''%>"
                required
                class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" />
            </div>
            <div>
              <label class="block text-gray-700 font-semibold mb-2">Last Name</label>
              <input type="text" name="lastName"
                placeholder="Last Name" value="<%=oldInput!=='undefined'?oldInput.lastName:''%>"
                required
                class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" />
            </div>
          </div>

          <div class="mb-6">
            <label class="block text-gray-700 font-semibold mb-2">Email Address</label>
            <input type="email" name="email"
              placeholder="your@email.com"
              value="<%=oldInput!=='undefined'?oldInput.email:''%>"
              required
              class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" />
          </div>

          <div class="mb-6">
            <label class="block text-gray-700 font-semibold mb-2">Password</label>
            <input type="password" name="password"
              placeholder="Create a strong password"
              required
              class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" />
          </div>
          
          <div class="mb-6">
            <label class="block text-gray-700 font-semibold mb-2">Confirm Password</label>
            <input type="password" name="confirmPassword"
              placeholder="Re-enter your password"
              required
              class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" />
          </div>
          
          <div class="mb-6 p-4 bg-blue-50 rounded-lg">
            <label class="flex items-start cursor-pointer group">
              <input type="checkbox" name="termsAccepted" class="w-4 h-4 text-red-500 rounded focus:ring-2 focus:ring-red-500 mt-1" <%= oldInput && oldInput.termsAccepted === 'on' ? 'checked' : '' %> required>
              <span class="ml-3 text-sm text-gray-700 group-hover:text-red-600">I accept the <a href="#" class="text-red-500 font-semibold hover:underline">terms and conditions</a></span>
            </label>
          </div>
          
          <input type="submit" value="Create My Account"
            class="w-full bg-gradient-to-r from-red-500 to-red-600 text-white py-3 rounded-lg hover:shadow-lg hover:from-red-600 hover:to-red-700 cursor-pointer font-semibold transition duration-300" />
          
          <p class="text-center text-gray-600 mt-6">Already have an account? <a href="/login" class="text-red-500 font-semibold hover:text-red-700">Login here</a></p>
        </form>
      </div>
    </div>
  </main>
</body>
</html>